# Скопируй в .streamlit/secrets.toml и заполни своими значениями.
# Этот файл (без .example) никогда не коммитить — он в .gitignore.

[gcp_service_account]
type = "service_account"
project_id = "..."
private_key_id = "..."
private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
client_email = "oinarri-bot@....iam.gserviceaccount.com"
client_id = "..."
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "..."
universe_domain = "googleapis.com"

# ID таблиц — из URL Google Sheets: .../d/ЭТОТ_ID/edit
[sheets]
data_spreadsheet_id = "..."     # "Мыловарня: Учёт"
access_spreadsheet_id = "..."   # "Мыловарня: Доступы"
