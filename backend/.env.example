# Локально не нужен — backend читает .streamlit/secrets.toml из корня репозитория напрямую.
# На проде (Railway/Render), где этого файла нет, задай вместо него:
JWT_SECRET=change-me-to-a-random-string
CORS_ORIGINS=http://localhost:3000
